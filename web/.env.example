# Backend public URL — used by the browser to call /v1/auth/*, /v1/billing/*, etc.
NEXT_PUBLIC_API_URL=http://localhost:3000

# Backend URL used by Next.js server components.
# In dev this is the same as the public one; in prod it can target an internal hostname.
API_URL=http://localhost:3000

# Public base URL of the website (no trailing slash). Used for canonical tags,
# hreflang alternates, sitemap.xml, robots.txt and FAQ JSON-LD. Defaults to
# https://aicorrect.app when unset.
NEXT_PUBLIC_SITE_URL=https://aicorrect.app
