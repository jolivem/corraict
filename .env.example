# Variables consommées par docker-compose.yml (production sur le VPS Hetzner).
# Copier en `.env` sur le VPS et remplir les valeurs sensibles.
# En dev local, ce fichier n'est pas lu : utiliser backend/.env et web/.env.

# --- Tags des images publiées sur ghcr.io ------------------------------------
BACKEND_IMAGE_TAG=latest
WEB_IMAGE_TAG=latest

# --- URLs publiques (Caddy fait la terminaison TLS) --------------------------
PUBLIC_WEB_URL=https://aicorrect.app
PUBLIC_API_URL=https://api.aicorrect.app
# Domaine du cookie de session (avec leading dot pour partage entre sous-domaines)
SESSION_COOKIE_DOMAIN=.aicorrect.app

# --- MariaDB -----------------------------------------------------------------
MARIADB_DATABASE=aicorrect
MARIADB_USER=aicorrect
# Générer une longue chaîne aléatoire : openssl rand -base64 32
MARIADB_PASSWORD=
MARIADB_ROOT_PASSWORD=

# --- Mistral (clé serveur uniquement, jamais exposée client) -----------------
MISTRAL_API_KEY=

# --- Stripe (sandbox ou prod) ------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_TRIAL_DAYS=7

# --- Resend (envoi des codes de connexion) -----------------------------------
RESEND_API_KEY=
EMAIL_FROM=AiCorrect <no-reply@aicorrect.app>
