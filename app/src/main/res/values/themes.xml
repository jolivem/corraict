<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AiCorrect" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Accent bleu marine de la marque Plume (remplace le violet Material). -->
        <item name="colorPrimary">@color/brand_marine</item>
        <item name="colorPrimaryVariant">@color/brand_marine_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/brand_marine</item>
        <item name="colorSecondaryVariant">@color/brand_marine_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>

    <style name="Key">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:padding">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/key_text</item>
        <item name="android:background">@drawable/key_bg_inset</item>
        <item name="android:backgroundTint">@color/key_surface</item>
    </style>

    <style name="KeyWide" parent="Key">
        <item name="android:layout_weight">1.5</item>
        <item name="android:backgroundTint">@color/key_surface_wide</item>
    </style>
</resources>
