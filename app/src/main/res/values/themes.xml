<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AiCorrect" parent="Theme.MaterialComponents.DayNight.DarkActionBar" />

    <style name="Key">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:padding">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/key_text</item>
        <item name="android:background">@drawable/key_bg</item>
        <item name="android:backgroundTint">@color/key_surface</item>
    </style>

    <style name="KeyWide" parent="Key">
        <item name="android:layout_weight">1.5</item>
        <item name="android:backgroundTint">@color/key_surface_wide</item>
    </style>
</resources>
