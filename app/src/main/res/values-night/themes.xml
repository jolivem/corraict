<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Thème de nuit. Le nom doit être EXACTEMENT « Theme.Plume » (C majuscule),
         comme dans le manifeste — sinon l'override de nuit est ignoré (ancien bug). -->
    <style name="Theme.Plume" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Marine plus clair en nuit pour le contraste (liens / texte sur fond sombre). -->
        <item name="colorPrimary">@color/brand_marine_light</item>
        <item name="colorPrimaryVariant">@color/brand_marine_dark</item>
        <item name="colorOnPrimary">@color/brand_on_marine_dark</item>
        <item name="colorSecondary">@color/brand_marine_light</item>
        <item name="colorSecondaryVariant">@color/brand_marine_dark</item>
        <item name="colorOnSecondary">@color/brand_on_marine_dark</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>

    <!-- Popups du clavier en nuit : accent marine plus clair pour le contraste. -->
    <style name="Theme.Plume.Dialog" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="colorPrimary">@color/brand_marine_light</item>
        <item name="colorOnPrimary">@color/brand_on_marine_dark</item>
    </style>
</resources>