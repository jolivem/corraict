NODE_ENV=development
PORT=3000

# MariaDB (matches docker-compose at repo root)
DATABASE_URL="mysql://aicorrect:aicorrect@localhost:3306/aicorrect"

# Mistral API — server-side only, never expose to clients
MISTRAL_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_TRIAL_DAYS=15

# Transactional email (Resend)
RESEND_API_KEY=
EMAIL_FROM="AiCorrect <no-reply@aicorrect.app>"

# Public web URL (used in emails and OAuth-style redirects)
PUBLIC_WEB_URL=http://localhost:3001
# Public URL of THIS API (api.aicorrect.app in prod). Used to build the
# single-use web-login link returned to the mobile app.
PUBLIC_API_URL=http://localhost:3000

# Auth code settings
AUTH_CODE_TTL_SECONDS=600
AUTH_CODE_LENGTH=6
AUTH_CODE_MAX_ATTEMPTS=5
AUTH_CODE_RATE_LIMIT_WINDOW_SECONDS=900
AUTH_CODE_RATE_LIMIT_MAX=5

# Test account for Google Play review / testers without inbox access.
# When BOTH are set: request-code sends no email for this address, and
# verify-code accepts this fixed code. Single account, no privileges.
# Leave empty to disable. Use a dedicated throwaway email + a 6-digit code.
TEST_LOGIN_EMAIL=
TEST_LOGIN_CODE=

# Web session (cookie httpOnly). 30 days by default.
SESSION_TTL_SECONDS=2592000
SESSION_COOKIE_NAME=aicorrect_session
# In dev leave empty; in prod set to ".aicorrect.app" if you need cross-subdomain.
# REQUIRED for the mobile web-login link: the cookie is set by api.aicorrect.app
# but must be valid on aicorrect.app, so set it to ".aicorrect.app" in prod.
SESSION_COOKIE_DOMAIN=
# Single-use mobile web-login ticket lifetime (seconds). Short on purpose.
WEB_LOGIN_TICKET_TTL_SECONDS=120

# /v1/correct settings
CORRECT_DEFAULT_MODEL=mistral-small-latest
CORRECT_MAX_INPUT_CHARS=5000
MISTRAL_TIMEOUT_MS=30000
MISTRAL_API_URL=https://api.mistral.ai/v1/chat/completions
