@echo off
REM ====================================================================
REM Modele de secrets LOCAUX pour les scripts de test Firebase.
REM
REM   1. Copier ce fichier en  firebase\secrets.local.bat
REM   2. Y coller tes vrais tokens (NE PAS commiter : secrets.local.bat est gitignore).
REM
REM run_test.bat et run_tests_local.bat appellent ce fichier s'il existe.
REM
REM  ACTIVE = compte ABONNE (ou compte de test TEST_LOGIN) -> la correction reussit.
REM  NOSUB  = compte GRATUIT ordinaire SANS abonnement -> popup "Veuillez vous abonner".
REM  Tokens crees depuis le dashboard web (section "Tokens pour l'app Android").
REM ====================================================================

set AICORRECT_TOKEN_ACTIVE=aic_REMPLACE_MOI
set AICORRECT_TOKEN_NOSUB=aic_REMPLACE_MOI
